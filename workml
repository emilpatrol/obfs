from google.colab import drive
import os
import torch
from unsloth import FastLanguageModel
from datasets import load_dataset
from trl import SFTTrainer
import shutil # Import shutil for rmtree
from huggingface_hub import snapshot_download
from unsloth import FastLanguageModel
from trl import SFTTrainer, SFTConfig

# Монтируем Google Диск
drive.mount('/content/drive', force_remount=True)

# Определяем пути на Диске для сохранения результатов
GDRIVE_DIR = "/content/drive/MyDrive/qwen_obfuscator_result"
os.makedirs(GDRIVE_DIR, exist_ok=True)

LOCAL_MODEL_DIR = "/content/drive/MyDrive/qwen_base_model"


max_seq_length = 2048
model, tokenizer = FastLanguageModel.from_pretrained(
    model_name = LOCAL_MODEL_DIR,
    max_seq_length = max_seq_length,
    dtype = None,
    load_in_4bit = True,
    local_files_only = True,
)
print("🎉 Модель успешно загружена!")

# ==============================================================================
# 2. НАСТРОЙКА LORA
# ==============================================================================
model = FastLanguageModel.get_peft_model(
    model,
    r = 16,
    target_modules = ["q_proj", "k_proj", "v_proj", "o_proj",
                      "gate_proj", "up_proj", "down_proj",],
    lora_alpha = 16,
    lora_dropout = 0,
    bias = "none",
    use_gradient_checkpointing = "unsloth",
    random_state = 3407,
)

# ==============================================================================
# 3. ПОДГОТОВКА ДАТАСЕТА
# ==============================================================================
alpaca_prompt = """Below is an instruction that describes a task, paired with an input that provides further context. Write a response that appropriately completes the request.

### Instruction:
{}

### Input:
{}

### Response:
{}"""

def formatting_prompts_func(examples):
    instructions = examples["instruction"]
    inputs       = examples["input"]
    outputs      = examples["output"]
    texts = []
    for instruction, input, output in zip(instructions, inputs, outputs):
        text = alpaca_prompt.format(instruction, input, output) + tokenizer.eos_token
        texts.append(text)
    return { "text" : texts, }

# Если файл лежит в корне Colab, оставляем так.
# Если хочешь читать его тоже с Диска, замени на f"{GDRIVE_DIR}/dataset_obfuscated.jsonl"
dataset = load_dataset("json", data_files={"train": "dataset_obfuscated.jsonl"}, split="train")
dataset = dataset.map(formatting_prompts_func, batched = True,)

# ==============================================================================
# 4. НАСТРОЙКА И ЗАПУСК ОБУЧЕНИЯ
# ==============================================================================
trainer = SFTTrainer(
    model = model,
    tokenizer = tokenizer,
    train_dataset = dataset,
    dataset_text_field = "text",
    max_seq_length = max_seq_length,
    dataset_num_proc = 2,
    packing = False,
    args = SFTConfig(
        per_device_train_batch_size = 2,
        gradient_accumulation_steps = 4,
        warmup_steps = 10,
        num_train_epochs = 1,
        learning_rate = 2e-4,
        fp16 = not torch.cuda.is_bf16_supported(),
        bf16 = torch.cuda.is_bf16_supported(),
        logging_steps = 10,
        optim = "adamw_8bit",
        weight_decay = 0.01,
        lr_scheduler_type = "linear",
        seed = 3407,

        # Настройки бэкапа на Google Диск:
        output_dir = f"{GDRIVE_DIR}/checkpoints",
        save_strategy = "steps",
        save_steps = 50,                         # Сохранять LoRA-адаптеры каждые 50 шагов
        save_total_limit = 2,                    # Хранить только 2 последних чекпоинта, чтобы экономить место
    ),
)

trainer.train()

# ==============================================================================
# 5. СОХРАНЕНИЕ РЕЗУЛЬТАТОВ НА GOOGLE ДИСК
# ==============================================================================
# Сохраняем финальные LoRA веса
model.save_pretrained(f"{GDRIVE_DIR}/my_obfuscator_lora")
tokenizer.save_pretrained(f"{GDRIVE_DIR}/my_obfuscator_lora")
print(f"Обучение завершено! Адаптеры сохранены на Диск: {GDRIVE_DIR}/my_obfuscator_lora")

# ==============================================================================
# 6. ТЕСТОВАЯ ГЕНЕРАЦИЯ (ИНФЕРЕНС)
# ==============================================================================
FastLanguageModel.for_inference(model)

test_code_cs = """
using System;

public class Program
{
    public static int CalculateSum(int a, int b)
    {
        int result = a + b;
        Console.WriteLine("The sum is: " + result);
        return result;
    }
}
"""
test_instruction = "Obfuscate the following C# code."

inputs = tokenizer([alpaca_prompt.format(test_instruction, test_code_cs, "")], return_tensors = "pt").to("cuda")
outputs = model.generate(**inputs, max_new_tokens = 2048, use_cache = True)
print("\n=== ТЕСТОВЫЙ ВЫВОД МОДЕЛИ ===")
print(tokenizer.batch_decode(outputs, skip_special_tokens = True)[0])

# ==============================================================================
# 7. ЭКСПОРТ В GGUF НА GOOGLE ДИСК
# ==============================================================================
print("Запуск конвертации в GGUF напрямую на Google Диск...")
model.save_pretrained_gguf(f"{GDRIVE_DIR}/qwen_coder_7b_obfuscator_q4", tokenizer, quantization_method = "q4_k_m")
print(f"Все готово! Файл лежит в папке 'qwen_obfuscator'")
